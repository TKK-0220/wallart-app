<div class="diagnosis-form-wrapper">
  <h5 class="section-title">理想のアートサイズを診断</h5>

  <%= form_with model: @diagnosis_form, url: diagnoses_path, method: :post, local: true do |f| %>
    <%= render 'shared/error_messages', object: @diagnosis_form %>

    <div class="mb-3">
      <%= f.label :base_width, "設置場所の幅（mm）" %>
      <div class="help-text">
        <p class="help-title">★各項目の最小値</p>
        <p>・壁を選択した場合   縦向き: 199mm~ 横向き: 284mm~</p>
        <p>・家具を選択した場合   縦向き: 144mm~ 横向き: 205mm~</p>
      </div>
      <%= f.number_field :base_width, placeholder: "例: 1200 (半角)" %>
    </div>

    <div class="mb-3">
      <%= f.label :location_type, "設置場所" %>
      <%= f.select :location_type, [['壁', 'wall'], ['家具', 'furniture']] %>
    </div>

    <div class="mb-3">
      <%= f.label :direction, "アートの向き" %>
      <%= f.select :direction, [
        ['指定なし（両方表示）', ''],
        ['縦向き', 'vertical'],
        ['横向き', 'horizontal']
      ], include_blank: false %>
    </div>

    <%= f.submit "診断する" %>
  <% end %>
</div>
