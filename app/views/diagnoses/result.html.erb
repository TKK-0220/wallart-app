<div class="diagnosis-result-wrapper">
  <h2 class="result-title">診断結果</h2>

  <div class="result-content">
    <!-- 推奨サイズの表示 -->
    <div class="recommended-size">
      <p class="size-label">理想の大きさ</p>
      <p class="size-value"><%= @recommended_size %>mm</p>
    </div>

    <!-- 額縁リスト -->
    <div class="frames-section">
      <p class="section-label">理想に近い市販の額縁サイズ:</p>
      <ul class="frames-list">
        <% @frames.each do |frame| %>
          <li>
            <div class="frame-name"><%= frame.name %></div>
            <div class="frame-size">
              <%= frame.short_side %>mm × <%= frame.long_side %>mm
              <span class="frame-direction <%= frame.direction %>">
                <%= frame.direction == 'vertical' ? '縦向き' : '横向き' %>
              </span>
            </div>
          </li>
        <% end %>
      </ul>
    </div>

    <!-- 再診断ボタン -->
    <%= link_to "もう一度診断する", new_diagnosis_path, class: "retry-button" %>
  </div>
</div>
