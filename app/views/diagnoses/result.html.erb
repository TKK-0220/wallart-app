<!-- app/views/diagnoses/result.html.erb -->
<h2>診断結果</h2>

<p>理想の大きさ: <%= @recommended_size %>mm</p>


<p>理想に近い市販の額縁サイズ:</p>
<ul>
  <% @frames.each do |frame| %>
    <li>
      <%= frame.name %> - <%= frame.short_side %>mm × <%= frame.long_side %>mm(<%= frame.direction %>)
    </li>
  <% end %>
</ul>

<p><%= link_to "もう一度診断する",new_diagnosis_path %></p>



